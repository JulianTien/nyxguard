<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/map_light_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DFF7FAFF" />

    <View
        android:id="@+id/map_grid_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_guard_grid_overlay"
        android:alpha="0.78" />

    <ImageView
        android:id="@+id/map_route_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/ic_guard_route_preview" />

    <ImageButton
        android:id="@+id/btn_theme_toggle"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_home_theme_button"
        android:contentDescription="@string/theme_toggle"
        android:padding="14dp"
        android:src="@drawable/ic_moon_outline"
        app:tint="#FF2D3448" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/guard_status_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="22dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="26dp"
        app:cardElevation="0dp"
        app:strokeColor="#12000000"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="22dp"
            android:paddingVertical="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/guard_title_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/guard_proto_idle_title"
                    android:textColor="#FF172033"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_guard_status_dot" />

                    <TextView
                        android:id="@+id/guard_guardian_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/guard_idle_subtitle"
                        android:textColor="@color/revamp_success"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/guard_eta_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/guard_no_trip_eta_short"
                    android:textColor="@color/revamp_indigo"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/guard_subtitle_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/guard_no_trip_eta"
                    android:textColor="@color/revamp_text_muted"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/guard_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="-2dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="34dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="136dp">

            <View
                android:layout_width="72dp"
                android:layout_height="5dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_guard_sheet_handle" />

            <LinearLayout
                android:id="@+id/guard_active_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="62dp"
                        android:layout_height="62dp"
                        android:background="@drawable/bg_guard_icon_badge">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_nav_map"
                            app:tint="@color/revamp_indigo" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/guard_sheet_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/guard_destination_label"
                            android:textColor="@color/revamp_text_muted"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/guard_sheet_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/guard_idle_title"
                            android:textColor="#FF172033"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_center_map"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="74dp"
                        android:text="@string/guard_action_edit"
                        android:textAllCaps="false"
                        android:textColor="@color/revamp_indigo"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="#FFE8ECFF"
                        app:cornerRadius="24dp" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_trip"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:layout_marginTop="30dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/guard_action_end"
                    android:textAllCaps="false"
                    android:textColor="#FF172033"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:backgroundTint="#FFF3F4FA"
                    app:cornerRadius="26dp"
                    app:icon="@drawable/ic_stop_square"
                    app:iconGravity="textStart"
                    app:iconPadding="14dp"
                    app:iconTint="#FF172033" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/guard_idle_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/guard_idle_title_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/guard_idle_title"
                    android:textColor="#FF172033"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/guard_sheet_body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/guard_location_sheet_body"
                    android:textColor="@color/revamp_text_muted"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/guard_idle_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_start_walk"
                        style="@style/Widget.NyxGuard.RevampButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/guard_start_walk" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_start_ride"
                        style="@style/Widget.NyxGuard.RevampButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/guard_start_ride"
                        android:textColor="@color/revamp_indigo"
                        app:backgroundTint="@color/revamp_indigo_soft" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/fallback_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_nav_map"
            android:tint="?attr/colorOutlineVariant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/map_not_supported"
            android:textAppearance="@style/TextAppearance.NyxGuard.TitleMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/map_not_supported_hint"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_location"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

</FrameLayout>
