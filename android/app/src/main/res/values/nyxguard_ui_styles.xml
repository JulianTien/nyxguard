<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.NyxGuard.Display" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.NyxGuard.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.NyxGuard.Section" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.NyxGuard.CaptionStrong" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="Widget.NyxGuard.IconFab" parent="Widget.Material3.Button.IconButton.Filled">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Material3.Corner.Full</item>
        <item name="android:minWidth">44dp</item>
        <item name="android:minHeight">44dp</item>
    </style>
</resources>
