APP_ENV=production
LOG_LEVEL=INFO
JWT_SECRET_KEY=replace-with-production-jwt-secret
CORS_ALLOW_ORIGINS=https://app.example.com,https://preview.example.com
DATABASE_URL=postgresql://<user>:<password>@<prod-endpoint>/<database>?sslmode=require&channel_binding=require
DATABASE_URL_NON_POOLING=postgresql://<user>:<password>@<prod-direct-endpoint>/<database>?sslmode=require&channel_binding=require
OPENAI_API_KEY=
