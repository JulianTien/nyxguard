APP_ENV=preview
LOG_LEVEL=INFO
JWT_SECRET_KEY=replace-with-preview-jwt-secret
CORS_ALLOW_ORIGINS=https://preview.example.com
DATABASE_URL=postgresql://<user>:<password>@<preview-endpoint>/<database>?sslmode=require&channel_binding=require
DATABASE_URL_NON_POOLING=postgresql://<user>:<password>@<preview-direct-endpoint>/<database>?sslmode=require&channel_binding=require
OPENAI_API_KEY=
